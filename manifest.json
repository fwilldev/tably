{
  "manifest_version": 3,
  "name": "Tably",
  "version": "1.0.0",
  "description": "Minimalistic tab manager for your new tab page",
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "permissions": ["tabs", "storage", "history", "bookmarks"],
  "host_permissions": ["https://openrouter.ai/*"],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "search-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Search tabs in Tably"
    }
  }
}
